#!/usr/bin/env bash
# time2 - time a program with some nicer defaults for data

fmt="Time: %U user, %S kernel, %E wall\nCPU: %P\nMemory (Kb): %M"

# The -f format string is a GNU time feature. Prefer GNU time when present
# (gtime on macOS, or the system time on Linux); otherwise fall back to the
# built-in BSD time, whose -l flag reports the same timing + memory data
# (just in a fixed format) so no extra package is needed.
if command -v gtime >/dev/null 2>&1; then
  exec gtime -f "$fmt" "$@"
elif /usr/bin/time -f "" true >/dev/null 2>&1; then
  exec /usr/bin/time -f "$fmt" "$@"
else
  exec /usr/bin/time -l "$@"
fi
