#!/usr/bin/env bash

# Ensure an ssh-agent is available for the shell (this file is sourced).
#
# On macOS we rely on the built-in launchd-managed ssh-agent: it sets
# SSH_AUTH_SOCK automatically and integrates with the Keychain, so
# passphrases persist across reboots. To get the most from it, add to
# ~/.ssh/config:
#
#     Host *
#       UseKeychain yes
#       AddKeysToAgent yes
#
# On other systems (and in the rare macOS session where SSH_AUTH_SOCK
# isn't set) we launch a single, persistent ssh-agent ourselves, reusing
# one if it's already running.
#
# We don't call ssh-add here: that would prompt to decrypt keys on login
# even if you never use them. Instead the `ssh` wrapper checks for loaded
# keys (`ssh-add -l`) and calls `ssh-add` on demand -- 'lazy' unlocking,
# which is also slightly better for security.
#
# This provides a similar (but reduced) feature set to keychain.

# Prefer the macOS launchd agent when it's already wired up.
if [ "$(uname -s)" = "Darwin" ] && [ -n "$SSH_AUTH_SOCK" ]; then
	# shellcheck disable=SC2317  # reached when executed rather than sourced
	return 0 2>/dev/null || exit 0
fi

SSH_ENV=$HOME/.ssh/environment
TIMEOUT=3600

function start_agent {
	echo "Initialising new SSH agent..."
	/usr/bin/ssh-agent -t "${TIMEOUT}" > "${SSH_ENV}"
	chmod 600 "${SSH_ENV}"
	# shellcheck source=/dev/null
	source "${SSH_ENV}" > /dev/null
}

# Source SSH settings, if applicable
if [ -f "${SSH_ENV}" ]; then
	# shellcheck source=/dev/null
	source "${SSH_ENV}" > /dev/null
	ps -p "${SSH_AGENT_PID:-}" | grep ssh-agent > /dev/null || {
		start_agent;
	}
else
	start_agent;
fi
