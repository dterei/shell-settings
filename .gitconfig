[user]
	name = David Terei
	email = code@davidterei.com
[push]
	default = simple
[init]
	defaultBranch = main
[core]
	excludesfile = ~/.gitignore_global
	pager = delta
	# Large-repo perf: FSEvents monitor + untracked cache so status/add/commit
	# don't rescan the whole working tree.
	fsmonitor = true
	untrackedCache = true
[color]
	ui = true
[diff]
	ignoreSubmodules = dirty
	algorithm = histogram
[index]
	# compact, path-prefix-compressed index; skip index trailing-hash on write
	version = 4
	skipHash = true
[pull]
	rebase = true
[rebase]
	autosquash = true
[merge]
	# shows common ancestor in conflict markers — easier to resolve
	conflictstyle = zdiff3
[rerere]
	enabled = true
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[fetch]
	# keep commit-graph fresh (fast log/blame/merge-base); prune deleted branches
	writeCommitGraph = true
	prune = true
