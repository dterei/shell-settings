# Common Environmental Variables File
#
# Designed to be shared among different shells and computers
#
# Author: David Terei

# Enable 256 colors. Ideally should confiugre your terminal emulator to do
# this, but dumb Gnome doesn't have an option.
# if [ -z "$TMUX" ] ; then
#   export TERM="xterm-256color"
# fi

# Disable archaic terminal features
#stty -ixon

# Stricter permissions just ends up causing issues, mostly as then sudo creates
# root files with broken permissions. This can be fixed by editing sudodoers,
# but fuck it... urgh.
# umask 007

# Editor (prefer neovim when available)
if command -v nvim >/dev/null 2>&1; then
  export EDITOR="nvim"
else
  export EDITOR="vim"
fi
export SVN_EDITOR="$EDITOR"
export VISUAL="$EDITOR"
export VIEWER="less"
export PAGER="less"
export LESS="-FR"
export HOSTNAME="${HOSTNAME:-${HOST:-$(hostname)}}"
GPG_TTY=$(tty)
export GPG_TTY

# Set tmpdir if not set
if [ -z "${TMPDIR}" ] ; then
  if [ -n "${TEMPDIR}" ] ; then
    export TMPDIR="${TEMPDIR}"
  elif [ -n "${TMP}" ] ; then
    export TMPDIR="${TMP}"
  else
    export TMPDIR="/tmp"
  fi
fi

# run ssh-agent if logged in via SSH (otherwise we rely on gnome).
if [ -n "$PS1" ]; then
  # No, needed for Windows, so running
  # if [ -n "$SSH_CLIENT"  ] || [ -n "$SSH_TTY"  ]; then
    source ~/.scripts/ssh-agent-startup
  # fi
fi

# Fix stupid Ubuntu
if command -v fdfind &>/dev/null; then
  alias fd=fdfind
fi

# use fd for fzf, supports .gitignore
if command -v fd >/dev/null 2>&1; then
  export FZF_DEFAULT_COMMAND='fd --follow --hidden --type file'
  export FZF_CTRL_T_COMMAND='fd --hidden --follow --type file'
  export FZF_CTRL_T_OPTS="--ansi --preview 'bat --color=always {}'"
  export FZF_ALT_C_COMMAND='fd --hidden --follow --type directory'
fi

# Mac/OS X specifics
if [[ "$OSTYPE" =~ "darwin" ]]; then
  # XCode Tools
  if [ -d /Library/Developer/CommandLineTools/usr/bin ] ; then
    export PATH="/Library/Developer/CommandLineTools/usr/bin:${PATH}"
  fi

   # Brew
  if [ -d /usr/local/bin ] ; then
    export PATH="/usr/local/bin:/usr/local/sbin:${PATH}"
  fi
  if [ -x /opt/homebrew/bin/brew ] ; then
     eval "$(/opt/homebrew/bin/brew shellenv)"
  fi

   # Java (only export when a JDK is actually present)
  _java_home="$(/usr/libexec/java_home 2>/dev/null)"
  [ -n "$_java_home" ] && export JAVA_HOME="$_java_home"
  unset _java_home

  # Fix GPG Tools passphrase entry
  if [ -n "$SSH_CONNECTION" ]; then
    export PINENTRY_USER_DATA="USE_CURSES=1"
  fi
fi

# Cabal bin
if [ -d ~/.cabal/bin/ ] ; then
  export PATH="${HOME}/.cabal/bin:${PATH}"
fi

# Load rbenv
if [ -d ~/.rbenv/bin/ ] ; then
  export PATH="${HOME}/.rbenv/bin:${PATH}"
  # manually do this as otherwise tmux doesn't work since it reloads the path
  # (duplicating entries) but rbenv checks the path and doesn't duplicate...
  # leading the the system ruby at the front.
  export PATH="${HOME}/.rbenv/shims:${PATH}"
fi
if command -v rbenv >/dev/null 2>&1; then
  eval "$(rbenv init -)"
fi

# AWS Credentials
if [ -f ~/.aws_credentials ] ; then
  source ~/.aws_credentials
fi

# Go
if [ -z "${GOROOT}" ]; then
  _GOROOT=${HOME}/Software/go
  if [ -d "${_GOROOT}" ]; then
    export GOROOT=${_GOROOT}
  fi
fi
if [ -d "${GOROOT}/bin" ]; then
  export PATH=${GOROOT}/bin:${PATH}
fi

# Gopath
if [ -z "${GOPATH}" ]; then
  export GOPATH="${HOME}/.go"
fi
if [ -d "${GOPATH}/bin" ]; then
  export PATH="${GOPATH}/bin:${PATH}"
fi

# Perf-tools
_PERFTOOLS=${HOME}/Software/perf-tools
if [ -d "${_PERFTOOLS}" ]; then
  export PATH=${_PERFTOOLS}/bin:${PATH}
  export MANPATH=${_PERFTOOLS}/man:${MANPATH}
fi

# NPM Global
if [ -d "${HOME}/.npm-global/bin" ]; then
  export PATH=${HOME}/.npm-global/bin:${PATH}
fi

# NVM
if [ -f /usr/share/nvm/init-nvm.sh ]; then
  source /usr/share/nvm/init-nvm.sh 2> /dev/null
fi

# Rustup
if [ -d "${HOME}/.cargo/bin" ]; then
  export PATH="$HOME/.cargo/bin:$PATH"
fi

# pyenv: put the shims on PATH eagerly (cheap, so python/pip resolve
# everywhere, including non-interactive shells), but defer the expensive
# `pyenv init -` shell integration until the first `pyenv` call to keep
# startup fast. (.shenv is sourced by every shell.)
if command -v pyenv &>/dev/null; then
  export PYENV_ROOT="$HOME/.pyenv"
  [ -d "$PYENV_ROOT/bin" ] && export PATH="$PYENV_ROOT/bin:$PATH"
  [ -d "$PYENV_ROOT/shims" ] && export PATH="$PYENV_ROOT/shims:$PATH"
  pyenv() {
    unset -f pyenv
    eval "$(command pyenv init -)"
    pyenv "$@"
  }
fi

# krewl
if [ -d "${KREW_ROOT:-$HOME/.krew}" ]; then
  export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
fi

# local bin
if [ -d ~/.local/bin ]; then
  export PATH="${HOME}/.local/bin:${PATH}"
fi

# Private scripts
if [ -d ~/.scripts ] ; then
  export PATH="${HOME}/.scripts:${PATH}"
fi

# Private executables
if [ -d ~/bin ] ; then
  export PATH="${HOME}/bin:${PATH}"
fi

# Keep PATH free of duplicates (they accumulate via macOS path_helper and
# nested/re-sourced shells). zsh handles this via `typeset -U path` in
# .zshenv; dedup manually for bash, keeping the first occurrence.
if [ -n "${BASH_VERSION}" ]; then
  PATH=$(awk -v RS=: -v ORS=: '!seen[$0]++' <<< "${PATH}")
  PATH=${PATH%:}
  export PATH
fi
